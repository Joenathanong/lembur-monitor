// firestore.rules
// Upload file ini ke Firebase Console → Firestore → Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Semua collection hanya bisa dibaca/ditulis dari domain Vercel Anda
    // Untuk tahap awal, izinkan semua request (GANTI setelah production)
    match /{document=**} {
      allow read, write: if true;
    }

    // ============================================================
    // SETELAH PRODUCTION — uncomment rule di bawah dan comment rule di atas
    // Ganti "your-app.vercel.app" dengan domain Vercel Anda
    // ============================================================
    // match /{document=**} {
    //   allow read, write: if request.time < timestamp.date(2030, 1, 1);
    // }
  }
}
